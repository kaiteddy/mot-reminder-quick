{
    "manifest_version": 3,
    "name": "Autodata Session Harvester",
    "version": "1.0",
    "description": "Extracts Autodata session keys from LocalStorage and syncs them.",
    "permissions": [
        "storage",
        "cookies"
    ],
    "host_permissions": [
        "https://workshop.autodata-group.com/*",
        "*://localhost/*",
        "https://mot-reminder-quick.vercel.app/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://workshop.autodata-group.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}